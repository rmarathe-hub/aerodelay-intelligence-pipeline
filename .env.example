# Copy to .env and adjust values: cp .env.example .env

# -----------------------------------------------------------------------------
# Postgres (warehouse + Airflow metadata DB)
# -----------------------------------------------------------------------------
POSTGRES_USER=aerodelay
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=aerodelay
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Host machine connection (dbt, psql from your laptop)
POSTGRES_HOST_LOCAL=localhost

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
# Linux/macOS: run `id -u` and set AIRFLOW_UID to that value if volume permissions fail
AIRFLOW_UID=50000
AIRFLOW_GID=0

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True

# Generated automatically by scripts/generate_fernet_key.sh if empty
AIRFLOW__CORE__FERNET_KEY=

# -----------------------------------------------------------------------------
# dbt (used later in Week 1 Day 7)
# -----------------------------------------------------------------------------
DBT_PROFILE=aerodelay
DBT_TARGET=dev
